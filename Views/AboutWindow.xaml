<Window x:Class="MinimalOptimizer2.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sobre e Créditos - Minimal Optimizer 2.0" 
        Height="640" 
        Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    
    <Window.Resources>
        <!-- Estilo para links, usando paleta global -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="0" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Padding="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Barra de título -->
            <Grid Grid.Row="0" Background="{StaticResource SecondaryBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="{DynamicResource About_TitleBar}" 
                          Foreground="{StaticResource TextBrush}"
                          FontSize="12"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="15,0"/>
                
                <Button Grid.Column="1" 
                        Name="CloseButton" 
                        Content="✕" 
                        Width="40" 
                        Height="40"
                        Background="Transparent"
                        Foreground="{StaticResource TextBrush}"
                        BorderThickness="0"
                        FontSize="12"
                        Click="CloseButton_Click"
                        Style="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="0" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFCC3333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
            <!-- Conteúdo principal -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="24">
                <StackPanel MaxWidth="480" HorizontalAlignment="Center">
                    
                    <!-- Logo e título -->
                    <Grid HorizontalAlignment="Center" Margin="0,24,0,28">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="../Resources/app.png" Width="90" Height="90" Margin="0,0,0,12"/>
                            <TextBlock Text="Minimal Optimizer 2.0" 
                                      FontSize="26" 
                                      FontWeight="Bold" 
                                      Foreground="{StaticResource TextBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource About_Subtitle}" 
                                      FontSize="12" 
                                      Foreground="{StaticResource SecondaryTextBrush}"
                                      HorizontalAlignment="Center"
                                      Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Desenvolvedor -->
                    <Border Background="{StaticResource SecondaryBackgroundBrush}" 
                            CornerRadius="0" 
                            Padding="18" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource About_Developer}" 
                                      FontSize="14" 
                                      FontWeight="SemiBold" 
                                      Foreground="{StaticResource AccentBrush}"
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="aMathyzin" 
                                      FontSize="16" 
                                      FontWeight="Bold" 
                                      Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Links oficiais -->
                    <Border Background="{StaticResource SecondaryBackgroundBrush}" 
                            CornerRadius="0" 
                            Padding="18" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource About_Links}" 
                                      FontSize="14" 
                                      FontWeight="SemiBold" 
                                      Foreground="{StaticResource AccentBrush}"
                                      Margin="0,0,0,10"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_Site}" 
                                          Foreground="{StaticResource TextBrush}" 
                                          VerticalAlignment="Center"
                                          Width="120"/>
                                <Button Content="https://amathyzin.com.br" 
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="WebsiteButton_Click"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_Discord}" 
                                          Foreground="{StaticResource TextBrush}" 
                                          VerticalAlignment="Center"
                                          Width="120"/>
                                <Button Content="https://discord.gg/XXquEjp69D" 
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="DiscordButton_Click"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_YouTube}" 
                                          Foreground="{StaticResource TextBrush}" 
                                          VerticalAlignment="Center"
                                          Width="120"/>
                                <Button Content="https://youtube.com/@aMathyzin" 
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="YouTubeButton_Click"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_GitHub}" 
                                          Foreground="{StaticResource TextBrush}" 
                                          VerticalAlignment="Center"
                                          Width="120"/>
                                <Button Content="GitHub Repository" 
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="GitHubButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Sobre o software -->
                    <Border Background="{StaticResource SecondaryBackgroundBrush}" 
                            CornerRadius="0" 
                            Padding="18" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource About_Software}" 
                                      FontSize="14" 
                                      FontWeight="SemiBold" 
                                      Foreground="{StaticResource AccentBrush}"
                                      Margin="0,0,0,10"/>
                            
                            <TextBlock Text="O Minimal Optimizer 2.0 é uma ferramenta avançada de otimização de sistema desenvolvida em .NET 8 com WPF. Oferece funcionalidades completas para limpeza de RAM, otimização de sistema e melhoria de performance do Windows."
                                      Foreground="{StaticResource TextBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="20"
                                      Margin="0,0,0,10"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_Framework}" 
                                          Foreground="#FFAAAAAA" 
                                          Width="120"/>
                                <TextBlock Text=".NET 8.0" 
                                          Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_Interface}" 
                                          Foreground="#FFAAAAAA" 
                                          Width="120"/>
                                <TextBlock Text="WPF (Windows Presentation Foundation)" 
                                          Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{DynamicResource About_Version}" 
                                          Foreground="#FFAAAAAA" 
                                          Width="120"/>
                                <TextBlock Text="2.0" 
                                          Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Licença / License -->
                    <Border Background="{StaticResource SecondaryBackgroundBrush}" 
                            CornerRadius="0" 
                            Padding="18" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource About_License}" 
                                      FontSize="14" 
                                      FontWeight="SemiBold" 
                                      Foreground="{StaticResource AccentBrush}"
                                      Margin="0,0,0,10"/>
                            
                            <TextBlock Text="{DynamicResource About_LicenseText}"
                                      Foreground="{StaticResource TextBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="20"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Copyright -->
                    <TextBlock Text="{DynamicResource About_Copyright}" 
                              FontSize="10" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              HorizontalAlignment="Center"
                              Margin="0,16,0,24"/>
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>