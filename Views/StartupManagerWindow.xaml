<Window x:Class="MinimalOptimizer2.Views.StartupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciador de Inicialização"
        Height="580" Width="820"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False">

    <Border Background="#0D0D0D" CornerRadius="12"
            BorderBrush="#2A2A2A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ───────────────────────────────────────────── -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border CornerRadius="12,12,0,0" Background="#111111"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="🚀" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Gerenciador de Inicialização"
                               Foreground="#DDDDDD" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border Background="#1A1A2E" CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="detecta mais que o Gerenciador de Tarefas"
                                   Foreground="#4455AA" FontSize="9"/>
                    </Border>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Margin="0,0,10,0"
                        Background="Transparent" Foreground="#666666"
                        BorderThickness="0" FontSize="13" Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="6,3">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center" FontSize="13"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CC2222"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ── Stats bar ───────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="#0A0A0A"
                    BorderBrush="#1E1E1E" BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TotalCountText" Text="…"
                                   Foreground="#888888" FontSize="11"/>
                        <TextBlock Text="  ·  " Foreground="#2E2E2E" FontSize="11"/>
                        <TextBlock x:Name="EnabledCountText" Text="…"
                                   Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="  ·  " Foreground="#2E2E2E" FontSize="11"/>
                        <TextBlock x:Name="DisabledCountText" Text="…"
                                   Foreground="#555555" FontSize="11"/>
                    </StackPanel>
                    <Button x:Name="RefreshButton" HorizontalAlignment="Right"
                            Content="↻  Recarregar"
                            Background="#1A1A1A" Foreground="#888888"
                            BorderBrush="#2E2E2E" FontSize="11" Cursor="Hand"
                            Click="RefreshButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="5" Padding="10,4">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="11" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Entries list ────────────────────────────────────────── -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,6,10,6">

                    <!-- Loading indicator -->
                    <TextBlock x:Name="LoadingText"
                               Text="🔍  Escaneando todos os locais de inicialização..."
                               Foreground="#444444" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,24,0,0"/>

                    <!-- Entries -->
                    <ItemsControl x:Name="EntriesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="12,9" CornerRadius="8"
                                        Background="#111111">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="#1E1E1E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                    <Setter Property="BorderBrush" Value="#3A1A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status dot -->
                                        <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Fill" Value="#333333"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                            <Setter Property="Fill" Value="#AA3333"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Name -->
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           MaxWidth="340" TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#DDDDDD"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Foreground" Value="#555555"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Location badge -->
                                                <Border Margin="8,0,0,0" Padding="5,1" CornerRadius="3"
                                                        Background="#131320" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Location}"
                                                               FontSize="9" Foreground="#4455AA"
                                                               FontFamily="Consolas"/>
                                                </Border>
                                                <!-- Missing file warning -->
                                                <TextBlock Text=" ⚠ arquivo ausente"
                                                           FontSize="9" Foreground="#AA3333"
                                                           VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Publisher -->
                                            <TextBlock Text="{Binding Publisher}"
                                                       FontSize="10" Foreground="#484848"
                                                       Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Publisher}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Command path -->
                                            <TextBlock Text="{Binding Command}" FontSize="9"
                                                       Foreground="#343434" FontFamily="Consolas"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Command}"/>
                                        </StackPanel>

                                        <!-- Toggle button -->
                                        <Button Grid.Column="2" Tag="{Binding}"
                                                MinWidth="94" Padding="10,5"
                                                Cursor="Hand" VerticalAlignment="Center"
                                                Click="ToggleEntry_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#1A2A1A"/>
                                                    <Setter Property="BorderBrush" Value="#2D652D"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="1" CornerRadius="6"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="0.75"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Opacity" Value="0.3"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="#1A1A1A"/>
                                                            <Setter Property="BorderBrush" Value="#303030"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⏸ Desativar"/>
                                                        <Setter Property="Foreground" Value="#66BB66"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="▶ Ativar"/>
                                                                <Setter Property="Foreground" Value="#666666"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer ──────────────────────────────────────────────── -->
            <Border Grid.Row="3" Background="#0A0A0A" CornerRadius="0,0,12,12"
                    BorderBrush="#1A1A1A" BorderThickness="0,1,0,0" Padding="14,0">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="Pronto"
                               Foreground="#3E3E3E" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="Alterações têm efeito no próximo reinício do sistema."
                               Foreground="#282828" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
