<Window x:Class="MinimalOptimizer2.Views.OptimizationSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title_Optimizations}" Height="400" Width="430"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Modern Toggle Switch Style with Smooth Animations -->
        <Style x:Key="ModernToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="ToggleBackground" 
                                    Width="44" Height="24" 
                                    CornerRadius="12" 
                                    Background="#333"
                                    BorderThickness="0">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="BackgroundScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                            </Border>
                            <Ellipse x:Name="ToggleThumb" 
                                     Width="18" Height="18" 
                                     Fill="White" 
                                     HorizontalAlignment="Left" 
                                     Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Animação do fundo -->
                                            <ColorAnimation Storyboard.TargetName="ToggleBackground"
                                                          Storyboard.TargetProperty="Background.Color"
                                                          To="#FF4444" Duration="0:0:0.3">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <!-- Animação do thumb -->
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                           Storyboard.TargetProperty="X"
                                                           To="23" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Pequena animação de escala no fundo -->
                                            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.05" Duration="0:0:0.15"
                                                           AutoReverse="True">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Animação do fundo de volta -->
                                            <ColorAnimation Storyboard.TargetName="ToggleBackground"
                                                          Storyboard.TargetProperty="Background.Color"
                                                          To="#333" Duration="0:0:0.25">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <!-- Animação do thumb de volta -->
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                           Storyboard.TargetProperty="X"
                                                           To="0" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.2"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ToggleBackground"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.8" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ToggleBackground"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="1.0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Red Apply Button Style -->
        <Style x:Key="RedButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="0" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF5555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DD3333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Scrollbar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Rectangle Fill="Transparent"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Rectangle Fill="#FF4444" RadiusX="3" RadiusY="3" Opacity="0.7"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#1a1a1a" BorderBrush="#FF4444" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="#222">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource Title_Optimizations}"
                           FontSize="15" FontWeight="Bold" Foreground="White"
                           Margin="20,0" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="✕" Width="30" Height="30" Margin="10"
                        Background="Transparent" Foreground="#999" BorderThickness="0"
                        FontSize="14" Click="CloseButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
            </Grid>

            <!-- Preset Cards -->
            <StackPanel Grid.Row="1" Margin="16,14,16,0">

                <!-- Card: Limpeza Rápida / Quick Cleanup -->
                <Border x:Name="CardQuick" Cursor="Hand"
                        Background="#252525" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,10"
                        BorderBrush="#40FF4444" BorderThickness="2"
                        MouseLeftButtonDown="CardQuick_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🧹" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                            <TextBlock Text="{DynamicResource Preset_Quick_Name}"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{DynamicResource Preset_Quick_Desc}"
                                       FontSize="11" Foreground="#aaa" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Ellipse Grid.Column="2" x:Name="DotQuick"
                                 Width="14" Height="14" Fill="#FF4444"
                                 VerticalAlignment="Center" Visibility="Collapsed">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF4444" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                </Border>

                <!-- Card: Otimização Completa / Full Optimization (default) -->
                <Border x:Name="CardFull" Cursor="Hand"
                        Background="#252525" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,10"
                        BorderBrush="#FF4444" BorderThickness="2"
                        MouseLeftButtonDown="CardFull_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚡" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Preset_Full_Name}"
                                           FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,8,0"/>
                                <Border Background="#33FF4444" CornerRadius="8" Padding="7,2" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Preset_Recommended}"
                                               FontSize="10" Foreground="#FF8888" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource Preset_Full_Desc}"
                                       FontSize="11" Foreground="#aaa" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Ellipse Grid.Column="2" x:Name="DotFull"
                                 Width="14" Height="14" Fill="#FF4444"
                                 VerticalAlignment="Center" Visibility="Visible">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF4444" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                </Border>

                <!-- Card: Foco em Jogos / Gaming Mode -->
                <Border x:Name="CardGaming" Cursor="Hand"
                        Background="#252525" CornerRadius="10"
                        Padding="16,14" Margin="0"
                        BorderBrush="#40FF4444" BorderThickness="2"
                        MouseLeftButtonDown="CardGaming_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎮" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                            <TextBlock Text="{DynamicResource Preset_Gaming_Name}"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{DynamicResource Preset_Gaming_Desc}"
                                       FontSize="11" Foreground="#aaa" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Ellipse Grid.Column="2" x:Name="DotGaming"
                                 Width="14" Height="14" Fill="#FF4444"
                                 VerticalAlignment="Center" Visibility="Collapsed">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF4444" BlurRadius="6" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="2" Background="#222">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="SelectionCount" Text=""
                           FontSize="11" Foreground="#999"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <Button Grid.Column="1" Content="{DynamicResource Btn_Apply}"
                        Margin="12" Padding="24,10"
                        Background="#FF4444" Foreground="White"
                        FontSize="13" FontWeight="SemiBold" BorderThickness="0"
                        Click="ApplyButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF5555"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

        </Grid>
    </Border>
</Window>