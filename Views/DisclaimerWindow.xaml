<Window x:Class="MinimalOptimizer2.Views.DisclaimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Minimal Optimizer" Height="620" Width="580"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Animação de fade-in para elementos -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
        
        <!-- Animação de slide-in da esquerda -->
        <Storyboard x:Key="SlideInLeft">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                           From="-30" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
        </Storyboard>
        
        <!-- Animação de pulse para o ícone de aviso -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="1" To="1.05" Duration="0:0:0.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Border CornerRadius="16" BorderThickness="1" BorderBrush="#44FF3333">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0D0D0D" Offset="0"/>
                <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                <GradientStop Color="#FF0D0D0D" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FF3333" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header com logo e título -->
            <StackPanel Grid.Row="0" x:Name="HeaderPanel" Opacity="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform/>
                </StackPanel.RenderTransform>
                
                <!-- Ícone de aviso animado -->
                <Border HorizontalAlignment="Center" Margin="0,0,0,16" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="WarningIconScale"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Ellipse Width="80" Height="80" Fill="#22FF3333"/>
                        <Ellipse Width="70" Height="70" Fill="#33FF3333"/>
                        <TextBlock Text="⚠️" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <TextBlock Text="{DynamicResource Disclaimer_Title}" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                
                <TextBlock Text="{DynamicResource Disclaimer_Subtitle}" 
                           FontSize="13" 
                           Foreground="#AAAAAA" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
            </StackPanel>
            
            <!-- Descrição principal -->
            <Border Grid.Row="1" x:Name="DescriptionPanel" Opacity="0" 
                    Background="#15FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                
                <StackPanel>
                    <TextBlock Text="{DynamicResource Disclaimer_WhatIs}" 
                               FontSize="14" FontWeight="SemiBold" 
                               Foreground="#FF6666" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Disclaimer_Description}" 
                               FontSize="12" Foreground="#CCCCCC" 
                               TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>
            
            <!-- Lista de funcionalidades -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <StackPanel x:Name="FeaturesPanel">
                    <!-- O que o Minimal faz -->
                    <TextBlock Text="{DynamicResource Disclaimer_WhatItDoes}" 
                               FontSize="13" FontWeight="SemiBold" 
                               Foreground="#FF6666" Margin="0,0,0,12" Opacity="0" x:Name="WhatItDoesTitle">
                        <TextBlock.RenderTransform>
                            <TranslateTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    
                    <StackPanel x:Name="FeaturesList">
                        <Border x:Name="Feature1" Opacity="0" Margin="0,0,0,8" Background="#10FFFFFF" CornerRadius="8" Padding="12,10">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧹" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Disclaimer_Feature1}" FontSize="12" Foreground="#CCCCCC" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border x:Name="Feature2" Opacity="0" Margin="0,0,0,8" Background="#10FFFFFF" CornerRadius="8" Padding="12,10">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Disclaimer_Feature2}" FontSize="12" Foreground="#CCCCCC" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border x:Name="Feature3" Opacity="0" Margin="0,0,0,8" Background="#10FFFFFF" CornerRadius="8" Padding="12,10">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎮" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Disclaimer_Feature3}" FontSize="12" Foreground="#CCCCCC" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border x:Name="Feature4" Opacity="0" Margin="0,0,0,8" Background="#10FFFFFF" CornerRadius="8" Padding="12,10">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Disclaimer_Feature4}" FontSize="12" Foreground="#CCCCCC" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border x:Name="Feature5" Opacity="0" Margin="0,0,0,8" Background="#10FFFFFF" CornerRadius="8" Padding="12,10">
                            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Disclaimer_Feature5}" FontSize="12" Foreground="#CCCCCC" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <!-- Aviso importante -->
                    <Border x:Name="WarningBox" Opacity="0" Margin="0,12,0,0" 
                            Background="#25FF3333" CornerRadius="10" Padding="14" BorderBrush="#44FF3333" BorderThickness="1">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="⚠️" FontSize="14"/>
                                <TextBlock Text="{DynamicResource Disclaimer_Warning}" 
                                           FontSize="13" FontWeight="SemiBold" 
                                           Foreground="#FF6666" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource Disclaimer_WarningText}" 
                                       FontSize="11" Foreground="#CCCCCC" 
                                       TextWrapping="Wrap" LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Checkbox de confirmação -->
            <Border Grid.Row="3" x:Name="CheckboxPanel" Opacity="0" Margin="0,0,0,16">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <CheckBox x:Name="AcceptCheckbox" 
                          Checked="AcceptCheckbox_Changed" 
                          Unchecked="AcceptCheckbox_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </CheckBox.Style>
                    <TextBlock Text="{DynamicResource Disclaimer_Accept}" TextWrapping="Wrap"/>
                </CheckBox>
            </Border>
            
            <!-- Botões -->
            <Grid Grid.Row="4" x:Name="ButtonsPanel" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" x:Name="ExitButton" 
                        Content="{DynamicResource Disclaimer_Exit}" 
                        Height="44" FontSize="14" 
                        Click="ExitButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#25FFFFFF"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#35FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button Grid.Column="2" x:Name="ContinueButton" 
                        Content="{DynamicResource Disclaimer_Continue}" 
                        Height="44" FontSize="14" FontWeight="SemiBold"
                        IsEnabled="False"
                        Click="ContinueButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ButtonBorder" CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF4444" Offset="0"/>
                                                    <GradientStop Color="#CC3333" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ButtonBorder" Property="Background" Value="#333333"/>
                                                <Setter Property="Foreground" Value="#666666"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsEnabled" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="ButtonBorder" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#FF5555" Offset="0"/>
                                                            <GradientStop Color="#DD4444" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
