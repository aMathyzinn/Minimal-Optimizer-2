                                    <Line X1="21" Y1="8" X2="21" Y2="14" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="27" Y1="8" X2="27" Y2="14" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="33" Y1="8" X2="33" Y2="14" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="39" Y1="8" X2="39" Y2="14" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="21" Y1="50" X2="21" Y2="56" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="27" Y1="50" X2="27" Y2="56" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="33" Y1="50" X2="33" Y2="56" Stroke="#FF3333" StrokeThickness="2"/>
