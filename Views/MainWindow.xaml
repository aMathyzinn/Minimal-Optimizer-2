                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource IconPulseAnimation}"/>
                                    </EventTrigger>
                                </Viewbox.Triggers>
                                <Canvas Width="64" Height="64">
