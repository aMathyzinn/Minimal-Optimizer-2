                                    <Line X1="24" Y1="50" X2="24" Y2="54" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="28" Y1="50" X2="28" Y2="54" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="32" Y1="50" X2="32" Y2="54" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="36" Y1="50" X2="36" Y2="54" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="40" Y1="50" X2="40" Y2="54" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="44" Y1="50" X2="44" Y2="54" Stroke="#FF3333" StrokeThickness="2"/>
                                </Canvas>
                            </Viewbox>
                            
                            <TextBlock Grid.Row="1" Text="RAM" Foreground="{StaticResource AccentBrush}" 
                                       FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" 
                                       Margin="0,0,0,6" Opacity="0.7" TextAlignment="Center"/>
                            
