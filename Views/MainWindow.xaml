                            <EllipseGeometry Center="80,80" RadiusX="75" RadiusY="75"/>
                        </Path.Data>
                        <Path.Stroke>
                            <RadialGradientBrush GradientOrigin="0.5,0.5">
                                <GradientStop Color="#FFFFB347" Offset="0.2"/>
                                <GradientStop Color="#FFFF6B35" Offset="0.5"/>
                                <GradientStop Color="#FFFF2B2B" Offset="0.8"/>
                                <GradientStop Color="#00FF0000" Offset="1"/>
                            </RadialGradientBrush>
                        </Path.Stroke>
                        <Path.Effect>
                            <DropShadowEffect Color="#FFFF5522" BlurRadius="18" ShadowDepth="0" Opacity="0.8"/>
                        </Path.Effect>
                    </Path>
                    
                    <!-- Imagem centralizada -->
                    <Image Source="../Resources/app.png" 
