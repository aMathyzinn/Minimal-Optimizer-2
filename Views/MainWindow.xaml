                                    <Line X1="22" Y1="32" X2="42" Y2="32" Stroke="#FF6666" StrokeThickness="1.4"/>
                                    <!-- Pinos laterais do chip -->
                                    <Line X1="8" Y1="21" X2="14" Y2="21" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="8" Y1="27" X2="14" Y2="27" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="8" Y1="33" X2="14" Y2="33" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="8" Y1="39" X2="14" Y2="39" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="50" Y1="21" X2="56" Y2="21" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="50" Y1="27" X2="56" Y2="27" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="50" Y1="33" X2="56" Y2="33" Stroke="#FF3333" StrokeThickness="2"/>
                                    <Line X1="50" Y1="39" X2="56" Y2="39" Stroke="#FF3333" StrokeThickness="2"/>
