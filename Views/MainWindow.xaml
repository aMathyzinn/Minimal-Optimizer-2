                            <DropShadowEffect Color="#FF3333" 
                                            BlurRadius="20" 
                                            ShadowDepth="0" 
                                            Opacity="0.7"/>
                        </Image.Effect>
                    </Image>
                </Grid>
                
                <!-- Informações do sistema em tempo real com ícones modernos -->
                <Grid Grid.Row="1" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- CPU Card -->
                    <Border Grid.Column="0" Background="{StaticResource SecondaryBackgroundBrush}" 
                            CornerRadius="12" Padding="18" Margin="5"
