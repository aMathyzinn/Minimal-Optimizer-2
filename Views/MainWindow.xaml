                                    <Rectangle Canvas.Left="32" Canvas.Top="26" Width="6" Height="10"
                                               Stroke="#FF6666" StrokeThickness="1" Fill="Transparent" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="40" Canvas.Top="26" Width="6" Height="10"
                                               Stroke="#FF6666" StrokeThickness="1" Fill="Transparent" RadiusX="1" RadiusY="1"/>
                                    <!-- Linha divisória -->
                                    <Line X1="14" Y1="38" X2="50" Y2="38" Stroke="#FF6666" StrokeThickness="1"/>
