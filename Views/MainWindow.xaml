                                           Margin="0,0,0,10">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF3333" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                
                                <!-- Mini barra de progresso -->
                                <Border Background="#15FFFFFF" CornerRadius="4" Height="4" Width="80">
                                    <Border x:Name="DiskProgressBar" Background="#FF3333" 
                                            CornerRadius="4" HorizontalAlignment="Left" Width="0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF3333" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock x:Name="DiskStatusLabel"
                                           Text="✅ Normal"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="#4CAF50"
                                           HorizontalAlignment="Center"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Módulos avançados + botões principais -->
                <StackPanel Grid.Row="2"
                            Orientation="Vertical"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,18">

                    <!-- Power Plan Quick Switch -->
                    <Border x:Name="PowerPlanCard"
                            Background="{StaticResource SecondaryBackgroundBrush}"
                            CornerRadius="10" BorderBrush="#FF2B2B2B" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,8"
                            HorizontalAlignment="Center">
                        <Border.Resources>
                            <Style x:Key="PlanBtnStyle" TargetType="Button">
                                <Setter Property="Background" Value="#FF252525"/>
                                <Setter Property="Foreground" Value="#FFAAAAAA"/>
                                <Setter Property="BorderBrush" Value="#FF444444"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF363636"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Border.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource PowerPlan_Label}"
                                       FontSize="11" Foreground="#FF777777"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button x:Name="PlanBalancedBtn"
                                    Content="{DynamicResource PowerPlan_Balanced}"
                                    Tag="381b4222-f694-41f0-9685-ff5bb260df2e"
                                    Style="{StaticResource PlanBtnStyle}"
                                    Margin="0,0,4,0"
                                    Click="PowerPlan_Click"/>
                            <Button x:Name="PlanHighBtn"
                                    Content="{DynamicResource PowerPlan_High}"
                                    Tag="8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c"
                                    Style="{StaticResource PlanBtnStyle}"
                                    Margin="0,0,4,0"
                                    Click="PowerPlan_Click"/>
                            <Button x:Name="PlanUltimateBtn"
                                    Content="{DynamicResource PowerPlan_Ultimate}"
                                    Tag="e9a42b02-d5df-448d-aa00-03f14749eb61"
                                    Style="{StaticResource PlanBtnStyle}"
                                    Click="PowerPlan_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Startup Programs Warning Card -->
                    <Border x:Name="StartupWarningCard"
                            Background="#0E1525"
                            CornerRadius="8" BorderBrush="#FF304060" BorderThickness="1"
                            Padding="12,7" Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            MinWidth="420"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock x:Name="StartupCountText"
                                           Text="🚀 ..."
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#FFBBCCFF"/>
                                <TextBlock x:Name="StartupHintText"
                                           Text=""
                                           FontSize="10" Foreground="#FF778899"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{DynamicResource Startup_Manage}"
                                    Click="StartupPrograms_Click"
                                    Background="Transparent"
                                    Foreground="#FF7799EE"
                                    Cursor="Hand"
                                    VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="#FF3355AA" BorderThickness="1"
                                                CornerRadius="5" Padding="10,4">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       FontSize="11" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <TextBlock Text="{DynamicResource Advanced_Modules}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                    
                    <!-- Removido: módulos extras. Mantido apenas os botões principais abaixo. -->

                    <!-- Botões de ação principais -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <!-- Botão Seletor de Otimizações -->
                        <Button x:Name="SelectorButton"
                                Content="{DynamicResource Btn_Configure}"
                                Background="#333333"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Padding="20,12"
                                MinWidth="180"
                                Height="52"
                                Cursor="Hand"
                                Margin="0,0,15,0"
                                Click="SelectorButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="0"
                                            BorderThickness="1"
                                            BorderBrush="#555555">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#333333" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#555555"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Agrupamento para o botão principal + GameBoost -->
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Center">
                            <!-- Botão Otimizar (estilo moderno com textura e shape) -->
                            <Button x:Name="OptimizeButton"
                                    Content="{DynamicResource Btn_Optimize}"
                                    Style="{StaticResource OptimizeButtonStyle}"
                                    Click="OptimizeButton_Click"/>

                            <!-- GameBoost: Botão + Controles lado a lado -->
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,0">
                                
                                <!-- Botão GameBoost -->
                                <Button x:Name="GameBoostButton"
                                        Content="{DynamicResource Btn_GameBoost_Activate}"
                                        Style="{StaticResource GameBoostButtonStyle}"
                                        ToolTip="Ativa o GameBoost automático quando um jogo suportado estiver aberto"
                                        VerticalAlignment="Center"
                                        Click="GameBoostButton_Click"/>

                                <!-- Card de controles ao lado do botão -->
                                <Border x:Name="GameBoostControlsCard"
                                        Background="{StaticResource SecondaryBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        Margin="12,0,0,0"
                                        BorderBrush="#40FF3333"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- ComboBox de agressividade -->
                                        <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                                            <TextBlock Text="{DynamicResource Label_Aggressiveness}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"
                                                       TextAlignment="Center"/>
                                            <ComboBox x:Name="GameBoostAggressivenessCombo"
                                                      Style="{StaticResource PillComboBoxStyle}"
                                                      SelectionChanged="GameBoostAggressivenessCombo_SelectionChanged"
                                                      Width="120">
                                                <ComboBoxItem Content="{DynamicResource Agg_Low}"/>
                                                <ComboBoxItem Content="{DynamicResource Agg_Medium}" IsSelected="True"/>
                                                <ComboBoxItem Content="{DynamicResource Agg_High}"/>
                                                <ComboBoxItem Content="{DynamicResource Agg_Extreme}"/>
                                            </ComboBox>
                                        </StackPanel>
                                        
                                        <!-- Badge de processos neutralizados -->
                                        <Button x:Name="SuspendedPanelButton"
                                                Content="{DynamicResource Suspended_NeutralizedCount_Zero}"
                                                Style="{StaticResource BadgeButtonStyle}"
                                                VerticalAlignment="Bottom"
                                                MinWidth="130"
                                                Click="SuspendedPanelButton_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Status do GameBoost com indicador visual aprimorado -->
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                <!-- Indicador de limpeza automática de RAM -->
                                <Border x:Name="RAMAutoCleanIndicator"
                                        Background="#22FF3333"
                                        CornerRadius="10"
                                        Padding="8,4"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="RAMCleanPulse" 
                                                 Width="6" Height="6" 
                                                 Fill="#00FF00" 
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#00FF00" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock x:Name="RAMCleanStatusText"
                                                   Text="Auto-Clean RAM: ON"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#00FF00"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Status principal do GameBoost - linha separada -->
                            <TextBlock x:Name="GameBoostStatusText"
                                       Text="{DynamicResource GameBoost_Waiting}"
                                       FontSize="12"
                                       Foreground="{StaticResource AccentBrush}"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>

                            <!-- Painel de processos suspensos (aparece quando solicitado) -->
                            <Border x:Name="SuspendedPanel"
                                    Background="{StaticResource SecondaryBackgroundBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,10,0,0"
                                    Width="500"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Processos pausados"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <ListBox x:Name="SuspendedProcessesList"
                                             Height="120"
                                             Margin="0,6,0,6"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Atualizar lista"
                                                Width="120"
                                                Click="SuspendedRefreshButton_Click"/>
                                        <Button Content="Retomar processo"
                                                Width="180"
                                                Margin="6,0,0,0"
                                                Click="SuspendedResumeSelectedButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Botão para criar ponto de restauração manualmente -->
                    <Button x:Name="CreateRestorePointButton"
                            Content="{DynamicResource Btn_Backup}"
                            Background="Transparent"
                            Foreground="#777"
                            BorderThickness="0"
                            FontSize="10"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0"
                            Cursor="Hand"
                            Click="CreateRestorePointButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextDecorations="Underline"
                                           HorizontalAlignment="Center"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#444444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Banner de resultado pós-otimização -->
                    <Border x:Name="OptimizationResultBanner"
                            Background="#1A2E1A"
                            BorderBrush="#4CAF50"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,12"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect Color="#4CAF50" BlurRadius="10" ShadowDepth="0" Opacity="0.35"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ResultCompletedText"
                                       Text="✅ Otimização concluída!"
                                       Foreground="#4CAF50"
                                       FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Border Background="#22FFFFFF" CornerRadius="6"
                                    Padding="12,4" Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾 " FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ResultRAMText"
                                               Text="0 MB liberados"
                                               Foreground="White" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="ResultTimeText"
                                       Text=""
                                       Foreground="#888" FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="14,0,0,0"/>
                            <Button Content="✕"
                                    Margin="12,0,0,0"
                                    Background="Transparent" Foreground="#666"
                                    BorderThickness="0" FontSize="13"
                                    VerticalAlignment="Center" Cursor="Hand"
                                    Click="ResultDismissButton_Click"
                                    Style="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   HorizontalAlignment="Center"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Session Statistics Strip -->
                    <Border x:Name="SessionStatsStrip"
                            Background="#0A0F0A"
                            CornerRadius="8" BorderBrush="#FF1E231E" BorderThickness="1"
                            Padding="14,7" Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊 Esta sessão:  "
                                       FontSize="11" Foreground="#FF555555"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="SessionOptCountText"
                                       Text="0 otimizações"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF7799BB"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="  ·  "
                                       FontSize="11" Foreground="#FF333333"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="SessionRAMText"
                                       Text="0 MB liberados"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF55AA77"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
                
                <!-- Área de saída de comandos + barra de progresso -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <Border
                            Grid.Row="0"
                            Background="{StaticResource SecondaryBackgroundBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Margin="0,0,0,0"
                            MinHeight="320"
                            ClipToBounds="True">
                        <!-- Tornar o terminal invisível aqui, pois passará a ser uma janela independente -->
                        <Border.Visibility>
                            <Visibility>Collapsed</Visibility>
                        </Border.Visibility>
                        <Border.Effect>
                            <DropShadowEffect Color="#FF3333" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Cabeçalho moderno do terminal -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource SecondaryBackgroundBrush}"
                                    CornerRadius="12,12,0,0"
                                    Padding="12,10"
                                    BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Terminal_Header}" 
                                                   Foreground="{StaticResource TextBrush}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="12"/>
                                        <!-- live badge -->
                                        <Border Background="#22FF3333" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#00FF00" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Terminal_LiveBadge}" Foreground="{StaticResource TextBrush}" FontSize="10" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Toolbar do terminal -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="AutoScrollToggle"
                                                      Content="{DynamicResource Toggle_AutoScroll_On}"
                                                      IsChecked="True"
                                                      Style="{StaticResource PillToggleStyle}"
                                                      Checked="AutoScrollToggle_Checked"
                                                      Unchecked="AutoScrollToggle_Unchecked"/>
                                        <Button Content="⎘" ToolTip="{DynamicResource Tooltip_CopyAll}" Margin="8,0,0,0"
                                                Style="{StaticResource ToolbarIconButtonStyle}" Click="Terminal_CopyAll_Click"/>
                                        <Button Content="🧹" ToolTip="{DynamicResource Tooltip_Clear}" Margin="8,0,0,0"
                                                Style="{StaticResource ToolbarIconButtonStyle}" Click="Terminal_Clear_Click"/>
                                        <Button Content="💾" ToolTip="{DynamicResource Tooltip_Save}" Margin="8,0,0,0"
                                                Style="{StaticResource ToolbarIconButtonStyle}" Click="Terminal_Save_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Conteúdo do terminal -->
                            <TextBox Grid.Row="1"
                                     x:Name="TerminalOutput"
                                     Style="{StaticResource TerminalTextBoxStyle}"
                                     Text="{DynamicResource Terminal_Ready}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalAlignment="Stretch"
                                     HorizontalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     Padding="15,12,15,12"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     FontSize="13">
                                <TextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copiar tudo" Click="Terminal_CopyAll_Click"/>
                                        <MenuItem Header="Limpar" Click="Terminal_Clear_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Salvar log" Click="Terminal_Save_Click"/>
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                            </TextBox>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Barra de progresso com efeito Flame -->
                <ProgressBar Grid.Row="2"
                             x:Name="ProgressBar"
                             Style="{StaticResource FlameProgressBarStyle}"
                             Maximum="100"
                             Value="0"
                             Margin="30,0,30,20"
                             VerticalAlignment="Bottom"
                             Visibility="Collapsed"
                             Panel.ZIndex="2"
                             IsHitTestVisible="False"/>
            </Grid>
            
            <!-- Rodapé com branding -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    CornerRadius="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              FontSize="10"
                              VerticalAlignment="Center"
                              Margin="15,0">
                        <Run Text="v2.0 | "/>
                        <Hyperlink NavigateUri="https://amathyzin.xyz" RequestNavigate="FooterLink_RequestNavigate" Foreground="{StaticResource SecondaryTextBrush}">
                            <Run Text="Powered by aMathyzin Studio"/>
                        </Hyperlink>
                    </TextBlock>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0">
                        <Ellipse Width="8" Height="8" Fill="#00FF00" Margin="0,0,5,0"/>
                        <TextBlock x:Name="StatusText" 
                                  Text="{DynamicResource Status_SystemOptimized}"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  FontSize="10"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Border>
</Window>
