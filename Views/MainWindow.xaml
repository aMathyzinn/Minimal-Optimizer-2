<Window x:Class="MinimalOptimizer2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Minimal Optimizer 2.0" 
        Height="800" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    
    <!-- Recursos da janela para animações e estilos -->
    <Window.Resources>
        <!-- Animação de pulso para ícones de monitoramento -->
        <Storyboard x:Key="IconPulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.8" To="1.0" Duration="0:0:1.5"
                           AutoReverse="True"/>
        </Storyboard>
        
        <!-- Animação de brilho para texto de porcentagem -->
        <Storyboard x:Key="PercentageGlowAnimation" RepeatBehavior="Forever">
            <ColorAnimation Storyboard.TargetProperty="(TextBlock.Effect).(DropShadowEffect.Color)"
                          From="#FF3333" To="#FF6666" Duration="0:0:2"
                          AutoReverse="True"/>
        </Storyboard>
        
        <!-- Estilo de barra de progresso com efeito Flame -->
        <Style x:Key="FlameProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="Root" ClipToBounds="True" SnapsToDevicePixels="True">
                            <!-- Base -->
                            <Border x:Name="PART_Track"
                                    Height="{TemplateBinding Height}"
                                    CornerRadius="7"
                                    BorderThickness="1"
                                    BorderBrush="#330000">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#220000" Offset="0"/>
                                         <GradientStop Color="#050000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="3"/>
                                </Border.Effect>
                            </Border>

                            <!-- Indicador preenchido -->
                            <Border x:Name="PART_Indicator"
                                    Height="{TemplateBinding Height}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="6"
                                    Margin="1,1,1,1"
                                    ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF5B1212" Offset="0"/>
                                        <GradientStop Color="#FFED4D1C" Offset="0.35"/>
                                        <GradientStop Color="#FFFFA24B" Offset="0.7"/>
                                        <GradientStop Color="#FFFF431D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect x:Name="IndicatorGlow" Color="#FFFF5A2A" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
                                </Border.Effect>

                                <Grid>
                                    <!-- textura interna -->
                                    <Rectangle Fill="#15FFFFFF"/>

                                    <!-- onda quente -->
                                    <Rectangle x:Name="HeatWave" Opacity="0.4">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#80FFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform X="-120"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>

                                    <!-- ponta de chama que acompanha o preenchimento -->
                                    <Grid x:Name="TipFlame"
                                          Width="56"
                                          HorizontalAlignment="Right"
                                          Margin="0,-10,-4,-6"
                                          RenderTransformOrigin="0.5,1">
                                        <Grid.RenderTransform>
                                            <ScaleTransform x:Name="TipScale" ScaleY="1"/>
                                        </Grid.RenderTransform>
                                        <Path x:Name="FlameBody" Data="M8,32 C18,5 40,0 56,32 L56,50 L8,50 Z">
                                            <Path.Fill>
                                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                    <GradientStop Color="#FFFFE29E" Offset="0"/>
                                                    <GradientStop Color="#FFFF8C3E" Offset="0.5"/>
                                                    <GradientStop Color="#FFFF3A1C" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Path.Fill>
                                            <Path.Effect>
                                                <BlurEffect Radius="5"/>
                                            </Path.Effect>
                                        </Path>
                                        <Ellipse x:Name="FlameSpark"
                                                 Width="16"
                                                 Height="16"
                                                 Fill="#FFFFF5CC"
                                                 Opacity="0.9"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Top"
                                                 Margin="0,-6,0,0">
                                            <Ellipse.RenderTransform>
                                                <TranslateTransform Y="0"/>
                                            </Ellipse.RenderTransform>
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#FFFFD071" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Grid>

                                    <!-- faíscas que correm pela barra -->
                                    <Canvas x:Name="SparkLayer" Height="14" Width="160" HorizontalAlignment="Right" IsHitTestVisible="False">
                                        <Ellipse x:Name="SparkTrail1" Width="6" Height="6" Fill="#FFFFF8D2" Opacity="0" Canvas.Left="-30" Canvas.Top="3">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="6"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse x:Name="SparkTrail2" Width="4" Height="4" Fill="#FFFFF8D2" Opacity="0" Canvas.Left="-60" Canvas.Top="8">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="4"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Canvas>
                                </Grid>
                            </Border>

                            <!-- Moldura externa -->
                            <Border x:Name="FlameFrame" CornerRadius="7" BorderThickness="1" BorderBrush="#FFFF3A3A" Background="Transparent">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FFFF3A3A" BlurRadius="8" ShadowDepth="0" Opacity="0.55"/>
                                </Border.Effect>
                            </Border>
                        </Grid>

                        <!-- Animações da chama -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="Visibility" Value="Visible">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <!-- Flicker -->
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IndicatorGlow"
                                                                           Storyboard.TargetProperty="BlurRadius">
                                                <LinearDoubleKeyFrame Value="15" KeyTime="0:0:0"/>
                                                <LinearDoubleKeyFrame Value="23" KeyTime="0:0:0.12"/>
                                                <LinearDoubleKeyFrame Value="18" KeyTime="0:0:0.24"/>
                                                <LinearDoubleKeyFrame Value="26" KeyTime="0:0:0.36"/>
                                                <LinearDoubleKeyFrame Value="17" KeyTime="0:0:0.48"/>
                                            </DoubleAnimationUsingKeyFrames>

                        <!-- Heat wave deslizando -->
                                            <DoubleAnimation Storyboard.TargetName="HeatWave"
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                            From="-150" To="260" Duration="0:0:0.9" RepeatBehavior="Forever"/>

                        <!-- Oscilação da chama -->
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TipScale"
                                                                           Storyboard.TargetProperty="ScaleY">
                                                <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0"/>
                                                <LinearDoubleKeyFrame Value="1.4" KeyTime="0:0:0.2"/>
                                                <LinearDoubleKeyFrame Value="0.9" KeyTime="0:0:0.35"/>
                                                <LinearDoubleKeyFrame Value="1.3" KeyTime="0:0:0.5"/>
                                                <LinearDoubleKeyFrame Value="1.0" KeyTime="0:0:0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FlameBody"
                                                                           Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame Value="0.8" KeyTime="0:0:0"/>
                                                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.2"/>
                                                <LinearDoubleKeyFrame Value="0.65" KeyTime="0:0:0.4"/>
                                                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.55"/>
                                            </DoubleAnimationUsingKeyFrames>

                        <!-- Faísca no topo -->
                                            <DoubleAnimation Storyboard.TargetName="FlameSpark"
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                            From="0" To="-18" Duration="0:0:0.45" AutoReverse="True" RepeatBehavior="Forever"/>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FlameSpark"
                                                                           Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame Value="0.2" KeyTime="0:0:0"/>
                                                <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.15"/>
                                                <LinearDoubleKeyFrame Value="0.3" KeyTime="0:0:0.45"/>
                                            </DoubleAnimationUsingKeyFrames>

                        <!-- Trilha de faíscas que percorrem a barra -->
                                            <DoubleAnimation Storyboard.TargetName="SparkTrail1"
                                                            Storyboard.TargetProperty="(Canvas.Left)"
                                                            From="-40" To="200" Duration="0:0:1.4" RepeatBehavior="Forever"/>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SparkTrail1"
                                                                           Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                                                <LinearDoubleKeyFrame Value="0.9" KeyTime="0:0:0.3"/>
                                                <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.9"/>
                                            </DoubleAnimationUsingKeyFrames>

                                            <DoubleAnimation Storyboard.TargetName="SparkTrail2"
                                                            Storyboard.TargetProperty="(Canvas.Left)"
                                                            From="-80" To="160" Duration="0:0:1.1" RepeatBehavior="Forever" BeginTime="0:0:0.2"/>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SparkTrail2"
                                                                           Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                                                <LinearDoubleKeyFrame Value="0.6" KeyTime="0:0:0.25"/>
                                                <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Animação otimizada para o glow durante otimização -->
        <Storyboard x:Key="OptimizingGlowAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="GlowRotation"
                           Storyboard.TargetProperty="Angle"
                           From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="FireRing"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="FireRing"
                           Storyboard.TargetProperty="StrokeThickness"
                           From="5.5" To="6.5"
                           AutoReverse="True"
                           Duration="0:0:0.4"
                           RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="FireRing"
                           Storyboard.TargetProperty="StrokeDashOffset"
                           From="0" To="-16"
                           Duration="0:0:0.5"
                           RepeatBehavior="Forever"/>
            <ColorAnimation Storyboard.TargetName="AnimatedGradient"
                          Storyboard.TargetProperty="GradientStops[2].Color"
                          From="#FF3333" To="#FF6666" Duration="0:0:2"
                          AutoReverse="True" RepeatBehavior="Forever"/>
            <ColorAnimation Storyboard.TargetName="AnimatedGradient"
                          Storyboard.TargetProperty="GradientStops[3].Color"
                          From="#DD3333" To="#FF4444" Duration="0:0:2"
                          AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>

        <!-- Gradiente e textura para o botão OTIMIZAR -->
        <LinearGradientBrush x:Key="OptimizeButtonGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF3A2E" Offset="0"/>
            <GradientStop Color="#FF1E1E" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OptimizeButtonHoverGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF4A3A" Offset="0"/>
            <GradientStop Color="#FF2A2A" Offset="1"/>
        </LinearGradientBrush>

        <VisualBrush x:Key="SoftTextureBrush" TileMode="Tile" Viewport="0,0,12,12" ViewportUnits="Absolute" Opacity="0.12">
            <VisualBrush.Visual>
                <Grid Width="12" Height="12" Background="Transparent">
                    <Rectangle Width="12" Height="12" Fill="Transparent"/>
                    <Rectangle Width="12" Height="1" VerticalAlignment="Top" Fill="#14FFFFFF"/>
                    <Rectangle Width="12" Height="1" VerticalAlignment="Center" Fill="#0EFFFFFF"/>
                    <Rectangle Width="12" Height="1" VerticalAlignment="Bottom" Fill="#14FFFFFF"/>
                </Grid>
            </VisualBrush.Visual>
        </VisualBrush>

        <!-- Estilo moderno do botão OTIMIZAR com textura, shape e animação de feedback -->
         <Style x:Key="OptimizeButtonStyle" TargetType="Button">
             <Setter Property="Background" Value="{StaticResource OptimizeButtonGradient}"/>
             <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
             <Setter Property="BorderThickness" Value="0"/>
             <Setter Property="FontSize" Value="18"/>
             <Setter Property="FontWeight" Value="SemiBold"/>
             <Setter Property="Padding" Value="24,12"/>
             <Setter Property="MinWidth" Value="240"/>
             <Setter Property="Height" Value="52"/>
             <Setter Property="Cursor" Value="Hand"/>
             <Setter Property="Template">
                 <Setter.Value>
                     <ControlTemplate TargetType="Button">
                         <Border x:Name="Root"
                                 Background="{TemplateBinding Background}"
                                 CornerRadius="0"
                                 BorderThickness="1"
                                 BorderBrush="#40FF3333"
                                 RenderTransformOrigin="0.5,0.5">
                             <Border.RenderTransform>
                                 <ScaleTransform ScaleX="1" ScaleY="1"/>
                             </Border.RenderTransform>
                             <Border.Effect>
                                 <DropShadowEffect Color="#FF3333" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                             </Border.Effect>
                             <Grid ClipToBounds="True">
                                 <!-- Textura suave -->
                                 <Rectangle Fill="{StaticResource SoftTextureBrush}"/>

                                 <!-- Brilho em varredura (sheen) -->
                                 <Rectangle x:Name="Sheen" Opacity="0" Width="60">
                                     <Rectangle.Fill>
                                         <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                             <GradientStop Color="#66FFFFFF" Offset="0"/>
                                             <GradientStop Color="#22FFFFFF" Offset="0.5"/>
                                             <GradientStop Color="#00FFFFFF" Offset="1"/>
                                         </LinearGradientBrush>
                                     </Rectangle.Fill>
                                     <Rectangle.RenderTransform>
                                         <TranslateTransform X="-220"/>
                                     </Rectangle.RenderTransform>
                                 </Rectangle>

                                 <!-- Conteúdo com ícone -->
                                 <Grid Margin="18,0">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="10"/>
                                         <ColumnDefinition Width="*"/>
                                     </Grid.ColumnDefinitions>
                                     <!-- Shape (ícone de raio estilizado) -->
                                     <Path Grid.Column="0" Width="16" Height="16" Stretch="Uniform"
                                           Fill="#FFFFEEEE" Opacity="0.9"
                                           Data="M2,10 L8,3 L6,10 L12,10 L6,17 L8,10 Z"/>
                                     <ContentPresenter Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                 </Grid>
                             </Grid>
                         </Border>

                         <!-- Triggers e animações -->
                         <ControlTemplate.Triggers>
                             <!-- Hover -->
                             <Trigger Property="IsMouseOver" Value="True">
                                 <Setter TargetName="Root" Property="Background" Value="{StaticResource OptimizeButtonHoverGradient}"/>
                                 <Setter TargetName="Root" Property="Effect">
                                     <Setter.Value>
                                         <DropShadowEffect Color="#FF3333" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
                                     </Setter.Value>
                                 </Setter>
                             </Trigger>

                             <!-- Press visual -->
                             <Trigger Property="IsPressed" Value="True">
                                 <Setter TargetName="Root" Property="RenderTransform">
                                     <Setter.Value>
                                         <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                     </Setter.Value>
                                 </Setter>
                             </Trigger>

                             <!-- Disabled -->
                             <Trigger Property="IsEnabled" Value="False">
                                 <Setter Property="Opacity" Value="0.6"/>
                             </Trigger>

                             <!-- Feedback de clique: pulso + varredura de brilho -->
                             <EventTrigger RoutedEvent="Button.Click">
                                 <BeginStoryboard>
                                     <Storyboard>
                                         <!-- Pulso -->
                                         <DoubleAnimation Storyboard.TargetName="Root"
                                                          Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                          To="0.97" Duration="0:0:0.10" AutoReverse="True"/>
                                         <DoubleAnimation Storyboard.TargetName="Root"
                                                          Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                          To="0.97" Duration="0:0:0.10" AutoReverse="True"/>
                                         <!-- Sheen: atravessa o botão -->
                                         <DoubleAnimation Storyboard.TargetName="Sheen"
                                                          Storyboard.TargetProperty="Opacity"
                                                          From="0" To="0.35" Duration="0:0:0.10" AutoReverse="True"/>
                                         <DoubleAnimation Storyboard.TargetName="Sheen"
                                                          Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                          From="-220" To="220" Duration="0:0:0.40"/>
                                     </Storyboard>
                                 </BeginStoryboard>
                             </EventTrigger>
                         </ControlTemplate.Triggers>
                 </ControlTemplate>
             </Setter.Value>
         </Setter>
     </Style>
     <!-- Estilo do sub-botão GameBoost -->
     <Style x:Key="GameBoostButtonStyle" TargetType="Button">
         <Setter Property="Background">
             <Setter.Value>
                 <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                     <GradientStop Color="#3C1414" Offset="0"/>
                     <GradientStop Color="#1C0606" Offset="1"/>
                 </LinearGradientBrush>
             </Setter.Value>
         </Setter>
         <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
         <Setter Property="BorderThickness" Value="0"/>
         <Setter Property="FontSize" Value="13"/>
         <Setter Property="FontWeight" Value="SemiBold"/>
         <Setter Property="Padding" Value="18,6"/>
         <Setter Property="MinWidth" Value="150"/>
         <Setter Property="Height" Value="34"/>
         <Setter Property="Cursor" Value="Hand"/>
         <Setter Property="Template">
             <Setter.Value>
                 <ControlTemplate TargetType="Button">
                     <Border x:Name="Root"
                             Background="{TemplateBinding Background}"
                             CornerRadius="6"
                             BorderThickness="1"
                             BorderBrush="#55FF4444"
                             RenderTransformOrigin="0.5,0.5">
                         <Border.RenderTransform>
                             <ScaleTransform ScaleX="1" ScaleY="1"/>
                         </Border.RenderTransform>
                         <Border.Effect>
                             <DropShadowEffect Color="#FF3333" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                         </Border.Effect>
                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                     </Border>
                     <ControlTemplate.Triggers>
                         <Trigger Property="IsMouseOver" Value="True">
                             <Setter TargetName="Root" Property="Background">
                                 <Setter.Value>
                                     <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                         <GradientStop Color="#4A1E1E" Offset="0"/>
                                         <GradientStop Color="#2A0C0C" Offset="1"/>
                                     </LinearGradientBrush>
                                 </Setter.Value>
                             </Setter>
                             <Setter TargetName="Root" Property="Effect">
                                 <Setter.Value>
                                     <DropShadowEffect Color="#FF5555" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                 </Setter.Value>
                             </Setter>
                         </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                         <Trigger Property="IsEnabled" Value="False">
                             <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                         </Trigger>
                     </ControlTemplate.Triggers>
                 </ControlTemplate>
             </Setter.Value>
         </Setter>
     </Style>

     <!-- Template do Toggle para ComboBox em formato pill -->
     <ControlTemplate x:Key="ComboPillToggleTemplate" TargetType="ToggleButton">
         <Border x:Name="Root"
                 Background="{TemplateBinding Background}"
                 BorderBrush="{TemplateBinding BorderBrush}"
                 BorderThickness="{TemplateBinding BorderThickness}"
                 CornerRadius="14">
             <Grid>
                 <ContentPresenter Margin="12,0,26,0" VerticalAlignment="Center"/>
                 <Path Data="M 0 0 L 8 0 L 4 5 Z"
                       Fill="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Right"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"/>
             </Grid>
         </Border>
         <ControlTemplate.Triggers>
             <Trigger Property="IsMouseOver" Value="True">
                 <Setter TargetName="Root" Property="BorderBrush" Value="#80FF3333"/>
             </Trigger>
             <Trigger Property="IsChecked" Value="True">
                 <Setter TargetName="Root" Property="Background" Value="#2A2A2A"/>
             </Trigger>
             <Trigger Property="IsEnabled" Value="False">
                 <Setter TargetName="Root" Property="Opacity" Value="0.6"/>
             </Trigger>
         </ControlTemplate.Triggers>
     </ControlTemplate>

     <!-- Estilo moderno para ComboBox em formato pill -->
     <Style x:Key="PillComboBoxStyle" TargetType="ComboBox">
         <Setter Property="Background" Value="#252525"/>
         <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
         <Setter Property="BorderBrush" Value="#40FF3333"/>
         <Setter Property="BorderThickness" Value="1"/>
         <Setter Property="Padding" Value="12,6"/>
         <Setter Property="Height" Value="28"/>
         <Setter Property="Template">
             <Setter.Value>
                 <ControlTemplate TargetType="ComboBox">
                     <Grid>
                         <ToggleButton x:Name="ToggleButton"
                                       Template="{StaticResource ComboPillToggleTemplate}"
                                       Background="{TemplateBinding Background}"
                                       Foreground="{TemplateBinding Foreground}"
                                       BorderBrush="{TemplateBinding BorderBrush}"
                                       BorderThickness="{TemplateBinding BorderThickness}"
                                       Padding="{TemplateBinding Padding}"
                                       IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Content="{TemplateBinding SelectionBoxItem}"
                                       Focusable="False"/>
                         <Popup x:Name="Popup"
                                Placement="Bottom"
                                StaysOpen="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False">
                             <Border Background="{StaticResource SecondaryBackgroundBrush}"
                                     BorderBrush="{StaticResource AccentBrush}"
                                     BorderThickness="1"
                                     CornerRadius="10">
                                 <ScrollViewer Margin="4" Focusable="False">
                                     <ItemsPresenter/>
                                 </ScrollViewer>
                             </Border>
                         </Popup>
                     </Grid>
                     <ControlTemplate.Triggers>
                         <Trigger Property="HasItems" Value="False">
                             <Setter TargetName="Popup" Property="MinWidth" Value="100"/>
                         </Trigger>
                     </ControlTemplate.Triggers>
                 </ControlTemplate>
             </Setter.Value>
         </Setter>
         <Setter Property="ItemContainerStyle">
             <Setter.Value>
                 <Style TargetType="ComboBoxItem">
                     <Setter Property="Background" Value="Transparent"/>
                     <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                     <Setter Property="Padding" Value="10,6"/>
                     <Setter Property="HorizontalContentAlignment" Value="Left"/>
                     <Setter Property="Template">
                         <Setter.Value>
                             <ControlTemplate TargetType="ComboBoxItem">
                                 <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                                     <ContentPresenter Margin="6,2,6,2"/>
                                 </Border>
                                 <ControlTemplate.Triggers>
                                     <Trigger Property="IsHighlighted" Value="True">
                                         <Setter TargetName="Border" Property="Background" Value="#22FFFFFF"/>
                                     </Trigger>
                                     <Trigger Property="IsSelected" Value="True">
                                         <Setter TargetName="Border" Property="Background" Value="#33FF3333"/>
                                     </Trigger>
                                 </ControlTemplate.Triggers>
                             </ControlTemplate>
                         </Setter.Value>
                     </Setter>
                 </Style>
             </Setter.Value>
         </Setter>
     </Style>

     <!-- Botão tipo badge para contador de neutralizados -->
     <Style x:Key="BadgeButtonStyle" TargetType="Button">
         <Setter Property="Background" Value="#252525"/>
         <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
         <Setter Property="BorderBrush" Value="#40FF3333"/>
         <Setter Property="BorderThickness" Value="1"/>
         <Setter Property="Padding" Value="12,6"/>
         <Setter Property="MinWidth" Value="150"/>
         <Setter Property="Height" Value="28"/>
         <Setter Property="Cursor" Value="Hand"/>
         <Setter Property="Template">
             <Setter.Value>
                 <ControlTemplate TargetType="Button">
                     <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                         <Grid>
                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0,8,0"/>
                             <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" HorizontalAlignment="Right" Margin="8,0,10,0" VerticalAlignment="Center"/>
                         </Grid>
                     </Border>
                     <ControlTemplate.Triggers>
                         <Trigger Property="IsMouseOver" Value="True">
                             <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                         </Trigger>
                         <Trigger Property="IsPressed" Value="True">
                             <Setter TargetName="Root" Property="RenderTransform">
                                 <Setter.Value>
                                     <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                 </Setter.Value>
                             </Setter>
                         </Trigger>
                     </ControlTemplate.Triggers>
                 </ControlTemplate>
             </Setter.Value>
         </Setter>
    </Style>
    
    <!-- Animação de gradiente GameBoost ativo -->
    <Storyboard x:Key="GameBoostActiveAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetName="GameBoostGradientRotation"
                        Storyboard.TargetProperty="Angle"
                        From="0" To="360" Duration="0:0:8"/>
        <DoubleAnimation Storyboard.TargetName="GameBoostOverlay"
                        Storyboard.TargetProperty="Opacity"
                        From="0" To="0.15" Duration="0:0:0.5"/>
    </Storyboard>
    
    <!-- Animação de pulso para indicador de RAM AutoClean -->
    <Storyboard x:Key="RAMCleanPulseAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                        From="0.5" To="1.0" Duration="0:0:1"
                        AutoReverse="True"/>
    </Storyboard>
    
    <!-- Estilo para card com efeito de brilho suave -->
    <Style x:Key="GlowCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SecondaryBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="#40FF3333"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF3333" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Estilo para status badge animado -->
    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#22FF3333"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10,4"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsActive}" Value="True">
                <Setter Property="Background" Value="#3300FF00"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
   </Window.Resources>
   
   <Border CornerRadius="0" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
       <Border.Effect>
           <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
       </Border.Effect>
       <Grid>
           <!-- Overlay de gradiente animado para GameBoost ativo -->
           <Border x:Name="GameBoostOverlay" 
                   Opacity="0"
                   IsHitTestVisible="False"
                   Panel.ZIndex="0">
               <Border.Background>
                   <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="1" RadiusY="1">
                       <RadialGradientBrush.RelativeTransform>
                           <RotateTransform x:Name="GameBoostGradientRotation" CenterX="0.5" CenterY="0.5" Angle="0"/>
                       </RadialGradientBrush.RelativeTransform>
                       <GradientStop Color="#00FF3333" Offset="0"/>
                       <GradientStop Color="#33FF3333" Offset="0.3"/>
                       <GradientStop Color="#55FF3333" Offset="0.6"/>
                       <GradientStop Color="#22FF3333" Offset="0.8"/>
                       <GradientStop Color="#00FF3333" Offset="1"/>
                   </RadialGradientBrush>
               </Border.Background>
           </Border>
           
       <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            
            <!-- Barra de título personalizada -->
            <Grid Grid.Row="0" Background="{StaticResource SecondaryBackgroundBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="Minimal Optimizer 2.0" 
                          Foreground="{StaticResource TextBrush}"
                          FontSize="12"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="15,0"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton x:Name="ModeToggle"
                                  Style="{StaticResource AppModeToggleStyle}"
                                  Margin="10,0,8,0"
                                  Checked="ModeToggle_Checked"
                                  Unchecked="ModeToggle_Unchecked"/>
                    <Button Name="AboutButton" 
                            Content="ℹ" 
                            Width="40" 
                            Height="40"
                            Background="Transparent"
                            Foreground="{StaticResource TextBrush}"
                            BorderThickness="0"
                            FontSize="14"
                            Click="AboutButton_Click"
                            ToolTip="Sobre e Créditos"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF444444"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FFFFFF" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="MinimizeButton" 
                            Content="—" 
                            Width="40" 
                            Height="40"
                            Background="Transparent"
                            Foreground="{StaticResource TextBrush}"
                            BorderThickness="0"
                            FontSize="14"
                            Click="MinimizeButton_Click"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF555555"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FFFFFF" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="CloseButton" 
                            Content="✕" 
                            Width="40" 
                            Height="40"
                            Background="Transparent"
                            Foreground="{StaticResource TextBrush}"
                            BorderThickness="0"
                            FontSize="12"
                            Click="CloseButton_Click"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0" BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFCC3333"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FF6666" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- Conteúdo principal -->
                <Grid Grid.Row="1" Margin="20,10,20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                
                <!-- Logo da aplicação com efeito de brilho animado -->
                <Grid Grid.Row="0" Width="160" Height="160" Margin="0,10,0,16">
                    
                    <!-- Border com gradiente animado -->
                    <Border x:Name="GlowBorder" 
                            Width="160" 
                            Height="160" 
                            CornerRadius="80"
                            BorderThickness="4"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush x:Name="AnimatedGradient" StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="0.3"/>
                                <GradientStop Color="#FF3333" Offset="0.5"/>
                                <GradientStop Color="#FF6666" Offset="0.6"/>
                                <GradientStop Color="#FF3333" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.RenderTransform>
                            <RotateTransform x:Name="GlowRotation" Angle="0"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard x:Name="NormalGlowAnimation" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="GlowRotation"
                                                   Storyboard.TargetProperty="Angle"
                                                   From="0" To="360" Duration="0:0:8"
                                                   RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    
                    <!-- Anel de brasa animado (visível durante otimização) -->
