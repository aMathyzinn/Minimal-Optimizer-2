                                        <Rectangle.Effect>
                                            <DropShadowEffect Color="#FF3333" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                        </Rectangle.Effect>
                                    </Rectangle>
                                    <!-- Dentes superiores (notch) -->
                                    <Path Data="M 18,18 L 18,20 L 24,20 L 24,18 Z M 26,16 L 26,20 L 32,20 L 32,16 Z M 34,18 L 34,20 L 40,20 L 40,18 Z M 42,18 L 42,20 L 46,20 L 46,18 Z"
                                          Stroke="#FF3333" StrokeThickness="1.5" Fill="Transparent"/>
