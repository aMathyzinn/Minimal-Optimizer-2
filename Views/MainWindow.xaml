                                           FontWeight="Bold" HorizontalAlignment="Center"
                                           Margin="0,0,0,10">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF3333" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                
                                <!-- Mini barra de progresso -->
                                <Border Background="#15FFFFFF" CornerRadius="4" Height="4" Width="80">
                                    <Border x:Name="RamProgressBar" Background="#FF3333" 
                                            CornerRadius="4" HorizontalAlignment="Left" Width="0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF3333" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock x:Name="RamStatusLabel"
